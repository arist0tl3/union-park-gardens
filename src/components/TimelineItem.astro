---
interface Props {
  year: string;
  title: string;
  description: string;
}

const { year, title, description } = Astro.props;
---

<div class="timeline-item">
  <div class="timeline-year">{year}</div>
  <div class="timeline-line"></div>
  <div class="timeline-body">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

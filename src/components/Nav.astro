---
import { FEATURE_FLAGS } from '../config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const communityLinks = [
  { href: '/events', label: 'Events' },
  { href: '/upgna', label: 'UPGNA' },
  { href: '/newsletters', label: 'Newsletters' },
  { href: '/contact', label: 'Contact Us' },
];

const links = [
  { href: '/history', label: 'History' },
  { href: '/archive', label: 'Archive' },
  ...(FEATURE_FLAGS.architecturePage ? [{ href: '/architecture', label: 'Architecture' }] : []),
  ...(FEATURE_FLAGS.merchPage ? [{ href: '/merch', label: 'Merch' }] : []),
];

const isCommunityActive = ['/community', '/events', '/upgna', '/newsletters', '/contact'].some(p => currentPath.startsWith(p));
---

<nav>
  <a href="/" class="nav-logo">UPG</a>
  <ul class="nav-links">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class:list={[{ active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      </li>
    ))}
    <li class="nav-dropdown">
      <a
        href="/community"
        class:list={['nav-dropdown-trigger', { active: isCommunityActive }]}
      >
        Community
      </a>
      <ul class="nav-dropdown-menu">
        {communityLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </li>
  </ul>
  <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>
</nav>
<div class="mobile-menu">
  <ul>
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class:list={[{ active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      </li>
    ))}
    <li class="mobile-community-group">
      <span class="mobile-community-label">Community</span>
      <ul class="mobile-community-links">
        {communityLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </li>
  </ul>
</div>

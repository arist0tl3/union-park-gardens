---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';

const boardMembers = [
  { name: 'First Last', title: 'President', image: '' },
  { name: 'First Last', title: 'Vice President', image: '' },
  { name: 'First Last', title: 'Treasurer', image: '' },
  { name: 'First Last', title: 'Secretary', image: '' },
  { name: 'First Last', title: 'Board Member', image: '' },
  { name: 'First Last', title: 'Board Member', image: '' },
];

const galleryPhotos = [
  { src: '', caption: 'Spring Cleanup 2025' },
  { src: '', caption: 'Annual Block Party' },
  { src: '', caption: 'Holiday Gathering' },
];
---

<BaseLayout title="UPGNA" description="The Union Park Gardens Neighborhood Association — meet the board and see what we're about.">
  <section class="page-header">
    <div class="section-inner">
      <SectionHeader eyebrow="Community" title="Neighborhood<br /><em>Association</em>" />
    </div>
  </section>

  <!-- Intro -->
  <section class="community-page">
    <div class="upgna-intro">
      <p class="lead">
        The Union Park Gardens Neighborhood Association (UPGNA) works to preserve the character of the neighborhood, advocate for residents, and bring people together.
      </p>
      <p>
        The board organizes quarterly meetings, coordinates with the city on neighborhood matters, plans community events, and helps maintain the shared spaces that make Union Park Gardens special.
      </p>
      <p>
        Meetings are open to all residents. Check the <a href="/events">events page</a> for the next one.
      </p>
    </div>
  </section>

  <!-- Board Members -->
  <section class="board-section">
    <div class="section-inner">
      <h3 class="board-heading">The Board</h3>
      <div class="board-grid">
        {boardMembers.map(member => (
          <div class="board-member">
            <div class="board-photo">
              {member.image ? (
                <img src={member.image} alt={member.name} />
              ) : (
                <div class="board-placeholder">
                  <span>{member.name.split(' ').map(n => n[0]).join('')}</span>
                </div>
              )}
            </div>
            <div class="board-name">{member.name}</div>
            <div class="board-title">{member.title}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Event Gallery -->
  {galleryPhotos.some(p => p.src) && (
    <section class="gallery-section">
      <div class="section-inner">
        <h3 class="board-heading">From Our Events</h3>
        <div class="gallery-grid">
          {galleryPhotos.filter(p => p.src).map(photo => (
            <div class="gallery-item">
              <img src={photo.src} alt={photo.caption} />
              <p class="photo-caption">{photo.caption}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .upgna-intro {
    max-width: 680px;
    margin: 0 auto;
  }

  .upgna-intro a {
    color: var(--stone);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .board-section {
    background: var(--cream);
  }

  .board-heading {
    font-family: var(--serif-display);
    font-size: 1.5rem;
    font-weight: 400;
    text-align: center;
    margin-bottom: 3rem;
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .board-member {
    text-align: center;
  }

  .board-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 1rem;
  }

  .board-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .board-placeholder {
    width: 100%;
    height: 100%;
    background: var(--parchment);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .board-placeholder span {
    font-family: var(--serif-display);
    font-size: 1.25rem;
    color: var(--warm-gray);
    letter-spacing: 0.05em;
  }

  .board-name {
    font-family: var(--serif-display);
    font-size: 1rem;
    color: var(--stone);
    margin-bottom: 0.25rem;
  }

  .board-title {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--warm-gray);
  }

  .gallery-section {
    background: var(--paper);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    filter: grayscale(100%);
    transition: filter 0.4s ease;
  }

  .gallery-item:hover img {
    filter: grayscale(60%);
  }

  @media (max-width: 700px) {
    .board-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';

const sections = [
  { href: '/events', label: 'Events', description: 'Cleanups, meetings, and neighborhood gatherings.' },
  { href: '/upgna', label: 'UPGNA', description: 'Meet the neighborhood association board.' },
  { href: '/newsletters', label: 'Newsletters', description: 'Past updates and how to stay in the loop.' },
  { href: '/contact', label: 'Contact Us', description: 'Questions, ideas, or just saying hello.' },
];
---

<BaseLayout title="Community" description="Get involved with Union Park Gardens — events, the neighborhood association, and ways to connect.">
  <section class="page-header">
    <div class="section-inner">
      <SectionHeader eyebrow="Get Involved" title="This is <em>your</em><br />neighborhood" />
    </div>
  </section>

  <section class="community-page">
    <div class="community-landing">
      <p class="lead" style="text-align:center;max-width:560px;margin:0 auto 3rem">
        Union Park Gardens has always been a place where neighbors know each other. Whether you've lived here for decades or just moved in, there's a place for you.
      </p>
      <div class="community-grid">
        {sections.map(section => (
          <a href={section.href} class="community-card">
            <h3>{section.label}</h3>
            <p>{section.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .community-landing {
    max-width: 780px;
    margin: 0 auto;
  }

  .community-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .community-card {
    display: block;
    padding: 2.5rem 2rem;
    border: 1px solid var(--parchment);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .community-card:hover {
    border-color: var(--light-gray);
    background: var(--cream);
  }

  .community-card h3 {
    font-family: var(--serif-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--stone);
    margin-bottom: 0.5rem;
  }

  .community-card p {
    font-size: 0.95rem;
    color: var(--warm-gray);
    margin: 0;
  }

  @media (max-width: 700px) {
    .community-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

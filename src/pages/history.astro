<BaseLayout title="History" description="The full story of Union Park Gardens — from parkland to wartime housing to enduring community.">
  <section class="page-header">
    <div class="section-inner">
      <SectionHeader eyebrow="The Full Story" title="From parkland<br /><em>to community</em>" />
    </div>

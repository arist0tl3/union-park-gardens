---
import { FEATURE_FLAGS } from '../config';

if (!FEATURE_FLAGS.merchPage) {
  return Astro.redirect('/');
}

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout title="Merch" description="Union Park Gardens merchandise — coming soon.">
  <section class="page-header">
    <div class="section-inner">
      <SectionHeader eyebrow="Merch" title="Coming <em>soon</em>" />
    </div>
  </section>

  <section style="padding:4rem 3rem;text-align:center">
    <div class="section-inner">
      <p class="lead" style="text-align:center">
        UPG-themed apparel and goods are on the way. Wordmark tees, the legendary UPG cats collection, and more.
      </p>
      <p style="text-align:center;color:var(--warm-gray)">
        Check back soon, or <a href="/community" style="color:var(--stone)">sign up for updates</a> to be the first to know.
      </p>
    </div>
  </section>
</BaseLayout>
